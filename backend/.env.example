# Django
SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL
POSTGRES_DB=tripe_logs
POSTGRES_USER=tripe_logs
POSTGRES_PASSWORD=tripe_logs
POSTGRES_HOST=localhost
# Use 5433 when Postgres runs via `docker compose up -d db` (host port mapping)
POSTGRES_PORT=5433
